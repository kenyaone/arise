<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /arise/admin/

# Don't rewrite existing files
RewriteCond %{REQUEST_FILENAME} !-f
# Don't rewrite existing directories
RewriteCond %{REQUEST_FILENAME} !-d
# Don't rewrite the index.php file itself
RewriteCond %{REQUEST_URI} !^/arise/admin/index\.php

# Rewrite everything else to index.php with the path as p parameter
RewriteRule ^(.*)$ index.php?p=$1 [QSA,L]
</IfModule>

# Security headers
<FilesMatch "\.(db|sqlite|json|txt)$">
    Order deny,allow
    Deny from all
</FilesMatch>
